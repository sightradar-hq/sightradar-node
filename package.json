{
  "name": "sightradar",
  "version": "1.0.1",
  "description": "Official Node.js / TypeScript client for the SightRadar face recognition API",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "face recognition",
    "facial recognition",
    "face recognition api",
    "face detection",
    "face search",
    "face matching",
    "face verification",
    "face compare",
    "aws rekognition alternative",
    "rekognition",
    "sightradar",
    "biometrics",
    "computer vision",
    "machine learning",
    "api",
    "typescript"
  ],
  "license": "MIT",
  "author": "SightRadar",
  "homepage": "https://sightradar.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/sightradar-hq/sightradar-node"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^20",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
